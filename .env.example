# Autotronic Environment Configuration
# Copy this to .env and fill in your values

# ===========================================
# SERVER CONFIGURATION
# ===========================================
NODE_ENV=production
PORT=3000

# ===========================================
# SECURITY (REQUIRED - CHANGE THESE!)
# ===========================================
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
ENCRYPTION_KEY=change-me-to-another-secure-random-string

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
POSTGRES_USER=autotronic
POSTGRES_PASSWORD=change-me
POSTGRES_DB=autotronic
# DATABASE_URL=postgresql://autotronic:change-me@postgres:5432/autotronic

# ===========================================
# REDIS (for job queue)
# ===========================================
REDIS_URL=redis://redis:6379
# REDIS_PASSWORD=change-me

# ===========================================
# CORS (comma-separated origins)
# ===========================================
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=info

# ===========================================
# AI PROVIDERS (optional)
# ===========================================
# OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ===========================================
# EMAIL (optional)
# ===========================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password
# EMAIL_FROM=noreply@your-domain.com

# ===========================================
# WEBHOOKS
# ===========================================
# WEBHOOK_SECRET=your-webhook-secret
